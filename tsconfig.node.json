{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "downlevelIteration": true,
    "target": "ES2020"
  },
  "include": ["vite.config.ts", "server/**/*.ts"]
}
