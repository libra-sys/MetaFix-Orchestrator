{
  "name": "metafix-orchestrator",
  "version": "1.0.0",
  "description": "MetaFix Orchestrator - 自主决策型 AI Agent 企业级智能缺陷修复系统",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node dist/server/index.js",
    "server": "tsx server/index.ts",
    "server:prod": "NODE_ENV=production node dist/server/index.js",
    "cli": "tsx cli/index.ts",
    "docker:build": "docker build -t metafix-orchestrator .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "init:git": "git init && git remote add origin https://github.com/libra-sys/MetaFix-Orchestrator.git"
  },
  "dependencies": {
    "@tdesign-react/aigc": "^0.1.0-alpha.1",
    "@tdesign-react/chat": "^1.0.2",
    "@tencent-ai/agent-sdk": "^0.3.43",
    "axios": "^1.7.0",
    "better-sqlite3": "^9.4.3",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "docx": "^9.7.0",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "lucide-react": "^0.563.0",
    "openai": "^4.0.0",
    "ora": "^8.0.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.28.0",
    "sqlite-vec": "^0.1.0",
    "tdesign-icons-react": "^0.5.0",
    "tdesign-react": "^1.12.0",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/commander": "^2.9.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "less": "^4.3.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vite": "^5.0.10"
  }
}
