# CodeBuddy API 配置
CODEBUDDY_API_KEY=your_codebuddy_api_key_here
CODEBUDDY_BASE_URL=https://api.codebuddy.cn

# 服务器配置
PORT=3001
NODE_ENV=development

# 数据库配置
DATABASE_PATH=./data/chat.db

# GitHub 配置（用于创建 PR）
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=libra-sys
GITHUB_REPO=MetaFix-Orchestrator

# 技能社区配置
SKILL_REGISTRY_URL=https://api.codebuddy.cn/skills
SKILL_CACHE_DIR=./data/skills

# 知识库配置
VECTOR_DB_PATH=./data/vectors.db
EMBEDDING_MODEL=text-embedding-3-small

# 成本控制
MAX_TOKENS_PER_SESSION=100000
MAX_COST_PER_SESSION=1.00

# 日志配置
LOG_LEVEL=info
LOG_DIR=./data/logs

# MCP 服务器配置
MCP_FILESYSTEM_ENABLED=true
MCP_GIT_ENABLED=true
MCP_GITHUB_ENABLED=true
MCP_LOGGING_ENABLED=true
